<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.day04.mapper.EmployeeMapper">

    <sql id="baseSelect">
        SELECT e.*, d.name AS department, dp.position_name AS position
        FROM employee e
        LEFT JOIN department_positions dp ON e.dept_pos_id = dp.id
        LEFT JOIN departments d ON dp.department_id = d.id
    </sql>

    <sql id="searchWhere">
        <where>
            <if test="criteria.name != null and criteria.name != ''">
                AND e.name LIKE CONCAT('%', #{criteria.name}, '%')
            </if>
            <if test="criteria.gender != null and criteria.gender != ''">
                AND e.gender = #{criteria.gender}
            </if>
            <if test="criteria.department != null and criteria.department != ''">
                AND d.name LIKE CONCAT('%', #{criteria.department}, '%')
            </if>
            <if test="criteria.position != null and criteria.position != ''">
                AND dp.position_name LIKE CONCAT('%', #{criteria.position}, '%')
            </if>
            <if test="criteria.minSalary != null">
                AND e.salary &gt;= #{criteria.minSalary}
            </if>
            <if test="criteria.maxSalary != null">
                AND e.salary &lt;= #{criteria.maxSalary}
            </if>
            <if test="criteria.minEntryDate != null">
                AND e.entry_date &gt;= #{criteria.minEntryDate}
            </if>
            <if test="criteria.maxEntryDate != null">
                AND e.entry_date &lt;= #{criteria.maxEntryDate}
            </if>
        </where>
    </sql>

    <select id="searchPage" resultType="Employee">
        <include refid="baseSelect"/>
        <include refid="searchWhere"/>
        LIMIT #{size} OFFSET #{offset}
    </select>

    <select id="count" resultType="long">
        SELECT COUNT(*)
        FROM employee e
        LEFT JOIN department_positions dp ON e.dept_pos_id = dp.id
        LEFT JOIN departments d ON dp.department_id = d.id
        <include refid="searchWhere"/>
    </select>

    <delete id="delete">
        DELETE FROM employee WHERE id = #{id}
    </delete>

    <insert id="insert">
        INSERT INTO employee (name, gender, dept_pos_id, salary, entry_date, last_operation_time)
        VALUES (#{name}, #{gender}, #{deptPosId}, #{salary}, #{entryDate}, NOW())
    </insert>

    <update id="edit">
        UPDATE employee
        SET name = #{employee.name},
            gender = #{employee.gender},
            dept_pos_id = #{employee.deptPosId},
            salary = #{employee.salary},
            entry_date = #{employee.entryDate},
            last_operation_time = NOW()
        WHERE id = #{id}
    </update>

</mapper>
